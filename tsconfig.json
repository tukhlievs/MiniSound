{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "ES2022",
    "moduleResolution":  "bundler",
    "lib":               ["ES2022"],
    "types":             ["@cloudflare/workers-types"],
    "strict":            true,
    "noImplicitAny":     true,
    "resolveJsonModule": true,
    "isolatedModules":   true
  },
  "include": ["worker/**/*"]
}
